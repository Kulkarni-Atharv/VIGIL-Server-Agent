# IP address of the PC running the Central Server (check with ipconfig)
SERVER_URL=http://192.168.1.100:8000

# Unique name for this Jetson device
JETSON_ID=jetson-01

# Must match the API_KEY in central_server/.env
API_KEY=vigil-secret-key-change-me

# How often (in seconds) to send a heartbeat
HEARTBEAT_INTERVAL=5

# Set to true on non-Jetson hardware (PC/VM) to simulate GPU & temperature
MOCK_JETSON_METRICS=false
